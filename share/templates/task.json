{
  "template_id": "task",
  "template_version": 1,
  "required_sections": [
    "Session Directive",
    "What's Next",
    "Application Context",
    "Position",
    "Key Files",
    "Task State",
    "Archived",
    "Constraints/Blockers",
    "Git State"
  ],
  "lints": {
    "V1": {"enabled": true, "target": "Session Directive"},
    "V7": {
      "enabled": true,
      "sub_lints": {
        "whats_next_file_ref": {"section": "What's Next", "pattern": "[A-Za-z0-9_/.-]+:[0-9]+", "min_matches": 1},
        "position_branch_head": {"section": "Position", "required_patterns": ["^- Branch:", "^- HEAD:"]}
      }
    },
    "V8": {"enabled": true, "pattern": "<<[A-Z_]+>>"}
  },
  "rolloff": {
    "strategy": "archive-checkbox",
    "source_section": "Task State",
    "target_section": "Archived",
    "trigger": "[x]"
  }
}
